# ── Environment / secrets ───────────────────────────────────────────────
**/.env
!**/.env.example

# ── Python ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.db
*.db-journal
backend/data/

# ── Node / frontend ─────────────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/.vite/
npm-debug.log*

# ── Editors / OS ────────────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db

# ── Docker ──────────────────────────────────────────────────────────────
data/

# ── Uploaded/test artifacts (do not commit real customer PCAPs by accident) ──
*.pcap
*.pcapng
*.cap
!backend/app/tests/fixtures/**/*.pcap
!backend/app/tests/fixtures/**/*.pcapng
