# Copy this file to .env and adjust as needed.
# docker-compose.yml automatically loads backend/.env if present.

# ── Database ──────────────────────────────────────────────────────────────
# Default: local SQLite file, zero setup required. Good for single-tester
# and small self-hosted deployments.
DATABASE_URL=sqlite+aiosqlite:///./data/voip_analyzer.db

# To use PostgreSQL instead (e.g. for heavier multi-user self-hosting):
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME

# ── PCAP Parser Backend ───────────────────────────────────────────────────
# "scapy"   (default) -- pure Python, no external binary required. Use this
#            unless you have a specific reason to need tshark's decoding.
# "pyshark" -- requires tshark installed (see backend/Dockerfile's
#            INSTALL_TSHARK build arg, or `apt install tshark` if running
#            outside Docker). Falls back to scapy automatically if tshark
#            is missing or fails to parse a file.
SIP_PARSER_BACKEND=scapy

# ── Upload limits ─────────────────────────────────────────────────────────
# Max size per uploaded PCAP file, in bytes. Default: 200MB.
# MAX_UPLOAD_SIZE_BYTES=209715200

# Max number of files accepted in a single /upload-pcap/batch request.
# MAX_BATCH_FILES=25
