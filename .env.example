# Copy this file to .env (at the repo root) to customize docker-compose.yml.
#
# This is separate from backend/.env.example and frontend/.env.example,
# which configure each service individually for non-Docker / local dev use.
# This file only affects values that docker-compose.yml itself reads at
# build time.

# The URL the BROWSER will use to reach the backend -- not the internal
# Docker network address. If you're self-hosting on a LAN and accessing the
# frontend from another machine, this needs to be your host's actual
# reachable address, e.g.:
# VITE_API_URL=http://192.168.1.50:8000
VITE_API_URL=http://localhost:8000
