# Copy this file to .env and adjust as needed.
# Only used for local development (`npm run dev`) and when building the
# production Docker image with a custom backend URL.

# Where the frontend should send API requests. Defaults to
# http://localhost:8000 if unset, which works for the default
# docker-compose.yml setup (frontend on :3000, backend on :8000, same host).
#
# Change this if you're running the backend on a different host/port, e.g.
# self-hosting on a LAN where the frontend and backend are exposed on
# different addresses:
# VITE_API_URL=http://192.168.1.50:8000
VITE_API_URL=http://localhost:8000
